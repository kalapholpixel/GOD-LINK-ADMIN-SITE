# Server
PORT=3000

# Comma-separated origins allowed to READ content
ALLOWED_READ_ORIGINS=https://client.example.com,https://admin.example.com

# Comma-separated origins allowed to SAVE content
ALLOWED_SAVE_ORIGINS=https://admin.example.com

# Require explicit origin allowlists when Origin header is present
CORS_DENY_BY_DEFAULT=true

# Secret required for POST /save and POST /api/auth/verify
SAVE_API_KEY=replace-with-a-long-random-secret

# EventSource reconnect hint in milliseconds
SSE_RETRY_MS=3000
